{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@amieira/customer-site",
    "build": "npm run build --workspace=@amieira/customer-site",
    "start": "npm run start --workspace=@amieira/customer-site",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint --workspaces --if-present -- --fix",
    "lint:ci": "npm run lint --workspaces --if-present -- --max-warnings 0",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "scan:raw-hex": "node scripts/check-raw-hex.mjs",
    "scan:mojibake": "node scripts/check-mojibake.mjs",
    "scan:routes": "node scripts/check-routes.mjs",
    "scan:dictionaries": "node scripts/check-dictionaries.mjs",
    "scan:hardcoded-admin-email": "node scripts/check-hardcoded-admin-email.mjs",
    "scan:gas": "node scripts/check-gas-syntax.mjs && node scripts/check-gas-parse.mjs",
    "scan:ci": "npm run scan:routes && npm run scan:mojibake && npm run scan:dictionaries && npm run scan:hardcoded-admin-email && npm run scan:gas && npm run scan:raw-hex",
    "verify:green": "npm run typecheck && npm run lint:ci && npm run scan:ci && npm run build --workspace=@amieira/customer-site && npm run build --workspace=@amieira/admin-app",
    "perf:k6": "k6 run perf/k6/dashboard-baseline.js",
    "perf:lighthouse": "lhci autorun --config=./lighthouserc.json"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@types/negotiator": "^0.6.3",
    "@types/node": "^20",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^11.0.0",
    "genkit-cli": "^1.20.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
